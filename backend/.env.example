# ---------------------------------------------------------------------------
# Backend environment — copy to `.env` and fill in.
# ---------------------------------------------------------------------------

# Node environment: development | production | test
NODE_ENV=development

# Port the API listens on
PORT=4000

# Where the frontend runs (for CORS in dev). In production behind Nginx this is
# same-origin and can be left as the deployed URL.
CORS_ORIGIN=http://localhost:5173

# --- Database ---------------------------------------------------------------
# DATABASE_URL: privileged/owner connection. Used for:
#   - Prisma migrations
#   - the NARROW auth surface (login lookup + signup transaction) via systemPrisma
#
# APP_DATABASE_URL: restricted runtime connection (role `crm_app`). Used by every
#   tenant request. Row Level Security is ENFORCED on this connection, so a
#   forgotten organization filter returns zero rows instead of leaking data.
#   If left blank, the app falls back to DATABASE_URL and logs a loud warning
#   that DB-level RLS is not being enforced (app-level scoping still applies).
#
# Local Postgres (after `npm run db:up` at the repo root):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/crm?schema=public"
APP_DATABASE_URL="postgresql://crm_app:crm_app_pw@localhost:5432/crm?schema=public"

# Supabase (production target) — from Project Settings → Database:
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
# APP_DATABASE_URL="postgresql://crm_app:[crm_app_password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# The password to assign the crm_app role when running `npm run db:roles`.
# Must match the password in APP_DATABASE_URL above.
CRM_APP_DB_PASSWORD="crm_app_pw"

# --- Auth -------------------------------------------------------------------
# Long random string. Generate one: `openssl rand -base64 48`
JWT_SECRET="change-me-in-production-use-a-64-char-random-string"
# Access token lifetime (jsonwebtoken format: 15m, 1h, 7d, ...)
JWT_EXPIRES_IN="7d"
# Cookie name for the session token
AUTH_COOKIE_NAME="crm_token"

# --- Later phases (not used in Phase 1; left here as a placeholder) ----------
# GEMINI_API_KEY=
# RESEND_API_KEY=
# TWILIO_ACCOUNT_SID=
# REDIS_URL=redis://localhost:6379

# --- Supabase Storage (image uploads) ---
# Create a PUBLIC bucket named "uploads" in Supabase → Storage, then set:
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service_role secret from Project Settings → API>
# SUPABASE_STORAGE_BUCKET=uploads

# --- Google Gemini (AI package generation) — optional ---
# Get a free key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
