// Travel Agency CRM — Prisma schema (Phase 1)
//
// Multi-tenant rules (PROJECT_SPEC.md §4):
//   - Every client-data table has an organization_id FK.
//   - Row Level Security is enabled + FORCED on every client-data table.
//     The RLS policies live in the migration SQL (Postgres feature, not
//     representable in this schema) — see prisma/migrations/*/migration.sql.
//
// `datasource.url` = DATABASE_URL (privileged) is used for migrations and the
// narrow auth surface (systemPrisma). The runtime tenant client connects with
// APP_DATABASE_URL (restricted `crm_app` role) so RLS is enforced. See
// src/lib/prisma.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  AGENT
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum LeadSource {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  WEBSITE
  REFERRAL
  WALK_IN
  PHONE
  MANUAL
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

// --- Phase 2 enums ---------------------------------------------------------

enum BookingStatus {
  PENDING
  CONFIRMED
  ONGOING
  COMPLETED
  CANCELLED
}

enum TaskType {
  FOLLOW_UP
  CALL
  MEETING
  OTHER
}

enum TaskStatus {
  PENDING
  DONE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum BillCategory {
  HOTEL
  FLIGHT
  TRANSPORT
  ACTIVITY
  VISA
  FOOD
  OTHER
}

enum BillStatus {
  UNPAID
  PAID
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

/// A travel agency (tenant). Every other client-data row is scoped to one of these.
model Organization {
  id                  String   @id @default(uuid()) @db.Uuid
  name                String
  slug                String   @unique
  logoUrl             String?
  brandPrimaryColor   String   @default("#4F46E5") @map("brand_primary_color")
  brandSecondaryColor String   @default("#0D9488") @map("brand_secondary_color")
  bio                 String?
  hostLinks           Json     @default("[]") @map("host_links")
  // --- Host Page mini-website ---
  bannerImageUrl      String?  @map("banner_image_url")
  aboutText           String?  @map("about_text")
  contactPhone        String?  @map("contact_phone")
  contactEmail        String?  @map("contact_email")
  address             String?
  linktreeCoverUrl    String?  @map("linktree_cover_url")
  /// LinkTree module theme (logo, bio, contacts, background, fonts) — separate
  /// from Host Page branding by design.
  linktreeTheme       Json     @default("{}") @map("linktree_theme")
  hostGallery         Json     @default("[]") @map("host_gallery") // Host Page gallery image URLs
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  users       User[]
  leads       Lead[]
  invitations Invitation[]
  hotels      Hotel[]
  packages    Package[]
  bookings    Booking[]
  itineraryItems ItineraryItem[]
  tasks       Task[]
  events      Event[]
  invoices    Invoice[]
  bills       Bill[]
  leadActivities LeadActivity[]
  sightseeing Sightseeing[]
  batches     Batch[]
  linktreeCategories LinktreeCategory[]
  packageLinktreeCategories PackageLinktreeCategory[]
  hostReviews HostReview[]

  @@map("organizations")
}

/// Reusable activity library. Simplified to just name + cover image + description.
/// These entries are a *content source*: picking one copies its values into a
/// package day (see PackageBuilder). Kept flat + searchable by name/description
/// so a future AI itinerary generator can query them.
model Sightseeing {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  imageUrl       String?  @map("image_url") // cover image (optional)
  notes          String? // description
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("sightseeing")
}

/// A customer review shown on the Host Page mini-website. Manually added by the
/// agency (not linked to bookings).
model HostReview {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  reviewerName   String   @map("reviewer_name")
  photoUrl       String?  @map("photo_url")
  quote          String
  rating         Int? // 1-5, optional
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, sortOrder])
  @@map("host_reviews")
}

/// LinkTree-specific category (per-org). Orders the tabs on the public
/// LinkTree page. Standalone — unrelated to the free-text Package.categories tags.
model LinktreeCategory {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  packages     PackageLinktreeCategory[]

  @@index([organizationId])
  @@index([organizationId, sortOrder])
  @@map("linktree_categories")
}

/// Many-to-many: a package can sit in several LinkTree categories.
/// Carries organization_id so RLS scopes it like every other client table.
model PackageLinktreeCategory {
  organizationId     String @map("organization_id") @db.Uuid
  packageId          String @map("package_id") @db.Uuid
  linktreeCategoryId String @map("linktree_category_id") @db.Uuid

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  package      Package          @relation(fields: [packageId], references: [id], onDelete: Cascade)
  category     LinktreeCategory @relation(fields: [linktreeCategoryId], references: [id], onDelete: Cascade)

  @@id([packageId, linktreeCategoryId])
  @@index([organizationId])
  @@index([linktreeCategoryId])
  @@map("package_linktree_categories")
}

/// A member of an organization. ADMINs manage the org + team; AGENTs work leads.
model User {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  email          String     @unique
  name           String
  passwordHash   String     @map("password_hash")
  role           Role       @default(AGENT)
  status         UserStatus @default(ACTIVE)
  lastLoginAt    DateTime?  @map("last_login_at")
  // Optional public profile, shown on the Host Page only when featured.
  featureOnHostpage Boolean @default(false) @map("feature_on_hostpage")
  publicPhotoUrl String?    @map("public_photo_url")
  publicTitle    String?    @map("public_title")
  publicBio      String?    @map("public_bio")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedLeads   Lead[]       @relation("AssignedAgent")
  invitationsSent Invitation[] @relation("Inviter")
  bookings        Booking[]    @relation("BookingAgent")
  tasks           Task[]       @relation("TaskAssignee")
  leadActivities  LeadActivity[] @relation("ActivityAuthor")

  @@index([organizationId])
  @@map("users")
}

/// An enquiry / prospective customer for a travel agency.
model Lead {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  name           String
  email          String?
  phone          String?
  source         LeadSource @default(MANUAL)
  status         LeadStatus @default(NEW)
  destination    String?
  travelDate     DateTime?  @map("travel_date") @db.Date
  travelerCount  Int?       @map("traveler_count")
  budgetAmount   Int?       @map("budget_amount") // whole units of budgetCurrency
  budgetCurrency String?    @default("USD") @map("budget_currency")
  notes          String?
  assignedToId   String?    @map("assigned_to_id") @db.Uuid
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedTo   User?        @relation("AssignedAgent", fields: [assignedToId], references: [id], onDelete: SetNull)
  bookings     Booking[]
  tasks        Task[]
  activities   LeadActivity[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([assignedToId])
  @@map("leads")
}

/// Interaction timeline for a lead: logged calls/notes/WhatsApp touches plus
/// automatic stage-change entries. Powers the Lead Activity Board.
model LeadActivity {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  leadId         String   @map("lead_id") @db.Uuid
  type           LeadActivityType @default(NOTE)
  outcome        String? // e.g. "Answered", "Call not picked"
  message        String?
  fromStatus     LeadStatus? @map("from_status")
  toStatus       LeadStatus? @map("to_status")
  createdById    String?  @map("created_by_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("ActivityAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([leadId, createdAt])
  @@map("lead_activities")
}

enum LeadActivityType {
  NOTE
  CALL
  WHATSAPP
  EMAIL
  MEETING
  STATUS_CHANGE
}

/// Pending invitation for a new team member. Only the token HASH is stored.
model Invitation {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  email          String
  role           Role             @default(AGENT)
  tokenHash      String           @unique @map("token_hash")
  status         InvitationStatus @default(PENDING)
  invitedById    String?          @map("invited_by_id") @db.Uuid
  expiresAt      DateTime         @map("expires_at")
  acceptedAt     DateTime?        @map("accepted_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User?        @relation("Inviter", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, email])
  @@map("invitations")
}

// ===========================================================================
// Phase 2 — Core CRM
// ===========================================================================

/// Partner hotel in the agency's directory.
model Hotel {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  city           String
  address        String?
  starRating     Int      @default(3) @map("star_rating")
  phone          String?
  email          String?
  pricePerNight  Int?     @map("price_per_night")
  currency       String   @default("INR")
  notes          String?
  images         Json     @default("[]") // photo URLs (Supabase Storage)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("hotels")
}

/// Reusable trip template ("Bali 5N/6D — ₹49,999").
model Package {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  name           String
  destination    String
  nights         Int     @default(1)
  days           Int     @default(2)
  priceAmount    Int     @map("price_amount")
  priceCurrency  String  @default("INR") @map("price_currency")
  description    String?
  inclusions     String?
  exclusions     String?
  isActive       Boolean @default(true) @map("is_active")
  showOnLinktree Boolean @default(false) @map("show_on_linktree")
  showOnHostpage Boolean @default(false) @map("show_on_hostpage")

  // --- Premium builder fields (Basics) ---
  code                String? // package code, auto-generated if blank
  slug                String? // public URL slug
  viewType            String  @default("CLASSIC") @map("view_type")
  categories          Json    @default("[]") // string[]
  bookingTitle        String? @map("booking_title")
  originalPrice       Int?    @map("original_price") // strike-through / discount
  pricingOptions      Json    @default("[]") @map("pricing_options") // {label, price}[]
  bannerImageUrl      String? @map("banner_image_url")
  whatsappBannerUrl   String? @map("whatsapp_banner_url")
  whatsappDescription String? @map("whatsapp_description")
  contactNumber       String? @map("contact_number")
  contactEmail        String? @map("contact_email")

  // --- Itinerary / logistics / policies / faqs / extras ---
  itinerary          Json    @default("[]") // {day, title, description}[]
  thingsToCarry      String? @map("things_to_carry")
  pickupPoints       String? @map("pickup_points")
  cancellationPolicy String? @map("cancellation_policy")
  paymentTerms       String? @map("payment_terms")
  termsConditions    String? @map("terms_conditions")
  faqs               Json    @default("[]") // {question, answer}[]
  highlights         Json    @default("[]") // string[]
  galleryImages      Json    @default("[]") @map("gallery_images") // string[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookings     Booking[]
  batches      Batch[]
  linktreeCategoryLinks PackageLinktreeCategory[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("packages")
}

/// A dated departure ("Event") of a package: a fixed date + seat capacity that
/// customers book onto. One package can have unlimited departures. Powers the
/// Events board and the Manage Departure page.
model Batch {
  id                String      @id @default(uuid()) @db.Uuid
  organizationId    String      @map("organization_id") @db.Uuid
  packageId         String      @map("package_id") @db.Uuid
  name              String? // optional event/batch label e.g. "Independence Day Special"
  departureDate     DateTime    @map("departure_date") @db.Date
  returnDate        DateTime?   @map("return_date") @db.Date
  bookingCloseDate  DateTime?   @map("booking_close_date") @db.Date
  capacity          Int         @default(20) // total seats
  pricePerPerson    Int?        @map("price_per_person") // defaults to package price when null
  pickupCity        String?     @map("pickup_city")
  coverImageOverride String?    @map("cover_image_override")
  status            EventStatus @default(DRAFT)
  notes             String?
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  package      Package      @relation(fields: [packageId], references: [id], onDelete: Cascade)
  bookings     Booking[]

  @@index([organizationId])
  @@index([packageId, departureDate])
  @@map("batches")
}

enum EventStatus {
  DRAFT
  LIVE
  COMPLETED
  CANCELLED
}

/// A confirmed (or in-progress) trip for a customer. BK-#### per organization.
model Booking {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  bookingNumber  Int           @map("booking_number")
  customerName   String        @map("customer_name")
  customerEmail  String?       @map("customer_email")
  customerPhone  String?       @map("customer_phone")
  destination    String
  startDate      DateTime?     @map("start_date") @db.Date
  endDate        DateTime?     @map("end_date") @db.Date
  travelerCount  Int?          @map("traveler_count")
  status         BookingStatus @default(PENDING)
  totalAmount    Int           @default(0) @map("total_amount")
  amountPaid     Int           @default(0) @map("amount_paid")
  currency       String        @default("INR")
  notes          String?
  leadId         String?       @map("lead_id") @db.Uuid
  packageId      String?       @map("package_id") @db.Uuid
  batchId        String?       @map("batch_id") @db.Uuid
  assignedToId   String?       @map("assigned_to_id") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead           Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  package        Package?        @relation(fields: [packageId], references: [id], onDelete: SetNull)
  batch          Batch?          @relation(fields: [batchId], references: [id], onDelete: SetNull)
  assignedTo     User?           @relation("BookingAgent", fields: [assignedToId], references: [id], onDelete: SetNull)
  itineraryItems ItineraryItem[]
  tasks          Task[]
  invoices       Invoice[]
  bills          Bill[]

  @@unique([organizationId, bookingNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, startDate])
  @@map("bookings")
}

/// One day (or item) of a booking's itinerary.
model ItineraryItem {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  bookingId      String   @map("booking_id") @db.Uuid
  dayNumber      Int      @map("day_number")
  title          String
  subtitle       String? // "what's happening" one-liner
  city           String?
  country        String?
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([bookingId, dayNumber])
  @@map("itinerary_items")
}

/// Scheduler entry / follow-up reminder — optionally linked to a lead or booking.
model Task {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  title          String
  notes          String?
  type           TaskType   @default(FOLLOW_UP)
  status         TaskStatus @default(PENDING)
  dueAt          DateTime   @map("due_at")
  leadId         String?    @map("lead_id") @db.Uuid
  bookingId      String?    @map("booking_id") @db.Uuid
  assignedToId   String?    @map("assigned_to_id") @db.Uuid
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  booking      Booking?     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  assignedTo   User?        @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, status, dueAt])
  @@index([leadId])
  @@index([bookingId])
  @@map("tasks")
}

/// Manual calendar entry (the departure calendar also merges bookings + tasks).
model Event {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  title          String
  date           DateTime @db.Date
  notes          String?
  color          String   @default("#4F46E5")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, date])
  @@map("events")
}

/// Customer invoice for a booking. INV-#### per organization; line items as JSON.
model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  invoiceNumber  Int           @map("invoice_number")
  bookingId      String?       @map("booking_id") @db.Uuid
  customerName   String        @map("customer_name")
  customerEmail  String?       @map("customer_email")
  customerPhone  String?       @map("customer_phone")
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime      @default(now()) @map("issue_date") @db.Date
  dueDate        DateTime?     @map("due_date") @db.Date
  items          Json          @default("[]")
  subtotal       Int           @default(0)
  taxPercent     Float         @default(0) @map("tax_percent")
  taxAmount      Int           @default(0) @map("tax_amount")
  total          Int           @default(0)
  currency       String        @default("INR")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking      Booking?     @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([bookingId])
  @@map("invoices")
}

/// Vendor cost (hotel, flight, transport…) tracked against a booking for margin.
model Bill {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  bookingId      String?      @map("booking_id") @db.Uuid
  vendorName     String       @map("vendor_name")
  category       BillCategory @default(OTHER)
  amount         Int
  currency       String       @default("INR")
  billDate       DateTime     @default(now()) @map("bill_date") @db.Date
  status         BillStatus   @default(UNPAID)
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking      Booking?     @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([bookingId])
  @@map("bills")
}
